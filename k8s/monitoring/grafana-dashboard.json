{
  "title": "Ynov-k3s DevSecOps",
  "uid": "ynov-k3s-devsecops",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Score CIS AVANT — VM2",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "cis_score{instance=\"vm2-before\"}", "legendFormat": "VM2 avant" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 40 }, { "color": "yellow", "value": 60 }, { "color": "green", "value": 75 }] } } }
    },
    {
      "id": 2,
      "title": "Score CIS APRÈS — VM2",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "cis_score{instance=\"vm2-after\"}", "legendFormat": "VM2 après" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 40 }, { "color": "yellow", "value": 60 }, { "color": "green", "value": 75 }] } } }
    },
    {
      "id": 3,
      "title": "Score CIS AVANT — VM3",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "cis_score{instance=\"vm3-before\"}", "legendFormat": "VM3 avant" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 40 }, { "color": "yellow", "value": 60 }, { "color": "green", "value": 75 }] } } }
    },
    {
      "id": 4,
      "title": "Score CIS APRÈS — VM3",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "cis_score{instance=\"vm3-after\"}", "legendFormat": "VM3 après" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 40 }, { "color": "yellow", "value": 60 }, { "color": "green", "value": 75 }] } } }
    },
    {
      "id": 5,
      "title": "Amélioration CIS — VM2",
      "type": "stat",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 4 },
      "targets": [{ "expr": "cis_score{instance=\"vm2-after\"} - ignoring(instance) cis_score{instance=\"vm2-before\"}", "legendFormat": "Delta VM2" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 5 }, { "color": "green", "value": 15 }] } } }
    },
    {
      "id": 6,
      "title": "Amélioration CIS — VM3",
      "type": "stat",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 4 },
      "targets": [{ "expr": "cis_score{instance=\"vm3-after\"} - ignoring(instance) cis_score{instance=\"vm3-before\"}", "legendFormat": "Delta VM3" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 5 }, { "color": "green", "value": 15 }] } } }
    },
    {
      "id": 7,
      "title": "Évolution du score CIS",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 6 },
      "targets": [
        { "expr": "cis_score{instance=\"vm2-before\"}", "legendFormat": "VM2 avant" },
        { "expr": "cis_score{instance=\"vm2-after\"}", "legendFormat": "VM2 après" },
        { "expr": "cis_score{instance=\"vm3-before\"}", "legendFormat": "VM3 avant" },
        { "expr": "cis_score{instance=\"vm3-after\"}", "legendFormat": "VM3 après" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "lineWidth": 2, "fillOpacity": 10 } } }
    },
    {
      "id": 10,
      "title": "CPU — VM2",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 14, "w": 6, "h": 4 },
      "targets": [{ "expr": "100 - (avg(rate(node_cpu_seconds_total{job=\"node-exporter\",mode=\"idle\"}[5m])) * 100)", "legendFormat": "CPU %" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 70 }, { "color": "red", "value": 90 }] } } }
    },
    {
      "id": 11,
      "title": "Mémoire — VM2",
      "type": "gauge",
      "gridPos": { "x": 6, "y": 14, "w": 6, "h": 4 },
      "targets": [{ "expr": "(1 - (node_memory_MemAvailable_bytes{job=\"node-exporter\"} / node_memory_MemTotal_bytes{job=\"node-exporter\"})) * 100", "legendFormat": "RAM %" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 75 }, { "color": "red", "value": 90 }] } } }
    },
    {
      "id": 12,
      "title": "Disque (/) — VM2",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 14, "w": 6, "h": 4 },
      "targets": [{ "expr": "(1 - (node_filesystem_avail_bytes{job=\"node-exporter\",mountpoint=\"/\"} / node_filesystem_size_bytes{job=\"node-exporter\",mountpoint=\"/\"})) * 100", "legendFormat": "Disque %" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 70 }, { "color": "red", "value": 85 }] } } }
    },
    {
      "id": 13,
      "title": "Uptime — VM2",
      "type": "stat",
      "gridPos": { "x": 18, "y": 14, "w": 6, "h": 4 },
      "targets": [{ "expr": "node_time_seconds{job=\"node-exporter\"} - node_boot_time_seconds{job=\"node-exporter\"}", "legendFormat": "Uptime" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } }
    },
    {
      "id": 20,
      "title": "CPU — VM3",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 18, "w": 6, "h": 4 },
      "targets": [{ "expr": "100 - (avg(rate(node_cpu_seconds_total{job=\"node-exporter-vm3\",mode=\"idle\"}[5m])) * 100)", "legendFormat": "CPU %" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 70 }, { "color": "red", "value": 90 }] } } }
    },
    {
      "id": 21,
      "title": "Mémoire — VM3",
      "type": "gauge",
      "gridPos": { "x": 6, "y": 18, "w": 6, "h": 4 },
      "targets": [{ "expr": "(1 - (node_memory_MemAvailable_bytes{job=\"node-exporter-vm3\"} / node_memory_MemTotal_bytes{job=\"node-exporter-vm3\"})) * 100", "legendFormat": "RAM %" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 75 }, { "color": "red", "value": 90 }] } } }
    },
    {
      "id": 22,
      "title": "Disque (/) — VM3",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 18, "w": 6, "h": 4 },
      "targets": [{ "expr": "(1 - (node_filesystem_avail_bytes{job=\"node-exporter-vm3\",mountpoint=\"/\"} / node_filesystem_size_bytes{job=\"node-exporter-vm3\",mountpoint=\"/\"})) * 100", "legendFormat": "Disque %" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 70 }, { "color": "red", "value": 85 }] } } }
    },
    {
      "id": 23,
      "title": "Uptime — VM3",
      "type": "stat",
      "gridPos": { "x": 18, "y": 18, "w": 6, "h": 4 },
      "targets": [{ "expr": "node_time_seconds{job=\"node-exporter-vm3\"} - node_boot_time_seconds{job=\"node-exporter-vm3\"}", "legendFormat": "Uptime" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } }
    },
    {
      "id": 30,
      "title": "CPU & RAM — VM2",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 6 },
      "targets": [
        { "expr": "100 - (avg(rate(node_cpu_seconds_total{job=\"node-exporter\",mode=\"idle\"}[5m])) * 100)", "legendFormat": "CPU %" },
        { "expr": "(1 - (node_memory_MemAvailable_bytes{job=\"node-exporter\"} / node_memory_MemTotal_bytes{job=\"node-exporter\"})) * 100", "legendFormat": "RAM %" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "lineWidth": 2, "fillOpacity": 10 } } }
    },
    {
      "id": 31,
      "title": "CPU & RAM — VM3",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 22, "w": 12, "h": 6 },
      "targets": [
        { "expr": "100 - (avg(rate(node_cpu_seconds_total{job=\"node-exporter-vm3\",mode=\"idle\"}[5m])) * 100)", "legendFormat": "CPU %" },
        { "expr": "(1 - (node_memory_MemAvailable_bytes{job=\"node-exporter-vm3\"} / node_memory_MemTotal_bytes{job=\"node-exporter-vm3\"})) * 100", "legendFormat": "RAM %" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "lineWidth": 2, "fillOpacity": 10 } } }
    },
    {
      "id": 40,
      "title": "Pods Running",
      "type": "stat",
      "gridPos": { "x": 0, "y": 28, "w": 6, "h": 3 },
      "targets": [{ "expr": "count(kube_pod_status_phase{phase=\"Running\"})", "legendFormat": "Running" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } } }
    },
    {
      "id": 41,
      "title": "Pods Pending",
      "type": "stat",
      "gridPos": { "x": 6, "y": 28, "w": 6, "h": 3 },
      "targets": [{ "expr": "count(kube_pod_status_phase{phase=\"Pending\"}) or vector(0)", "legendFormat": "Pending" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }] } } }
    },
    {
      "id": 42,
      "title": "Pods Failed",
      "type": "stat",
      "gridPos": { "x": 12, "y": 28, "w": 6, "h": 3 },
      "targets": [{ "expr": "count(kube_pod_status_phase{phase=\"Failed\"}) or vector(0)", "legendFormat": "Failed" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } }
    },
    {
      "id": 43,
      "title": "Deployments Ready",
      "type": "stat",
      "gridPos": { "x": 18, "y": 28, "w": 6, "h": 3 },
      "targets": [{ "expr": "sum(kube_deployment_status_replicas_ready)", "legendFormat": "Replicas ready" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } } }
    },
    {
      "id": 50,
      "title": "État des pods par namespace",
      "type": "table",
      "gridPos": { "x": 0, "y": 31, "w": 24, "h": 7 },
      "targets": [{ "expr": "kube_pod_status_phase", "legendFormat": "", "instant": true, "format": "table" }],
      "options": { "sortBy": [{ "desc": false, "displayName": "namespace" }] },
      "transformations": [{ "id": "filterFieldsByName", "options": { "include": { "names": ["namespace", "pod", "phase", "Value"] } } }]
    }
  ]
}
